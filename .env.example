# ============================================================================
# Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to the repository — it is in .gitignore.
#
# For Gmail App Password: enable 2FA at myaccount.google.com,
# then create an App Password at myaccount.google.com/apppasswords
# ============================================================================

# Alertmanager SMTP credentials
ALERTMANAGER_SMTP_FROM=your_project_email@gmail.com
ALERTMANAGER_SMTP_USERNAME=your_project_email@gmail.com
ALERTMANAGER_SMTP_PASSWORD=your_16_char_app_password
ALERTMANAGER_EMAIL_TO=team-oncall@example.com

# Grafana admin password (change from default 'admin' on first login)
GRAFANA_ADMIN_PASSWORD=change_me_on_first_login

# Prometheus data source URL (for Grafana)
PROMETHEUS_URL=http://localhost:9090
